# --- Database (Neon PostgreSQL) ---------------------------------------------
# Use the POOLED connection string from your Neon project dashboard.
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require"

# --- Admin console ----------------------------------------------------------
# Password for the /admin operations console. Change this before deploying.
ADMIN_PASSWORD="change-this-password"

# --- WhatsApp lead flow -----------------------------------------------------
# International format, digits only, no "+" or spaces. e.g. 2348030000000
NEXT_PUBLIC_WHATSAPP_NUMBER="234XXXXXXXXXX"

# --- Email notifications (optional) -----------------------------------------
# New submissions email an alert to your team. If these are unset, notifications
# are silently skipped and submissions still save normally.
# Get an API key at resend.com. NOTIFY_EMAIL_FROM must be a Resend-verified
# sender (or leave it to use the shared onboarding@resend.dev sandbox sender).
RESEND_API_KEY=""
NOTIFY_EMAIL_TO="ops@yourfirm.com"
NOTIFY_EMAIL_FROM="Magaji Law <alerts@yourdomain.com>"
