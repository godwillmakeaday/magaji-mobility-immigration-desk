// Magaji Law — Mobility & Immigration Desk
// Rust-engine-free client (driver adapters + query compiler) so it runs cleanly
// on Neon serverless / Vercel without a native query-engine binary.

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
  runtime  = "nodejs"
}

datasource db {
  provider = "postgresql"
}

enum MatterType {
  VISIT_VISA_TRAVEL_DOCUMENTATION
  WORK_ABROAD_JOB_OFFER
  STUDY_ABROAD
  AGENT_DISPUTE_REFUND
  DIASPORA_LEGAL_SUPPORT
  BUSINESS_INVESTOR_MOBILITY
  OTHER
}

enum PaymentStatus {
  NO_PAYMENT
  PARTIAL_PAYMENT
  FULL_PAYMENT
  ABOUT_TO_PAY
}

enum ContactMethod {
  WHATSAPP
  PHONE_CALL
  EMAIL
}

enum ReviewStatus {
  NEW
  REVIEWING
  AWAITING_CLIENT
  ACTION_REQUIRED
  REFERRED_TO_PARTNER
  CLOSED
}

enum RiskLevel {
  LOW_VISIBLE_RISK
  MODERATE_RISK
  HIGH_RISK
  SEVERE_RISK
}

enum RiskStatus {
  NEW
  REVIEWING
  CONTACTED
  CLOSED
}

enum AdminRole {
  OWNER
  STAFF
}

enum AuditAction {
  LOGIN_SUCCESS
  LOGIN_FAILURE
  LOGOUT
  REVIEW_STATUS_CHANGED
  REVIEW_NOTE_CHANGED
  RISK_STATUS_CHANGED
  RISK_NOTE_CHANGED
  DOCUMENT_UPLOADED
  DOCUMENT_DELETED
  USER_CREATED
  USER_DISABLED
  USER_ENABLED
  USER_ROLE_CHANGED
}

model AdminUser {
  id           String     @id @default(cuid())
  createdAt    DateTime   @default(now())
  email        String     @unique
  name         String
  passwordHash String
  role         AdminRole  @default(STAFF)
  disabled     Boolean    @default(false)
  lastLoginAt  DateTime?
  auditLogs    AuditLog[]

  @@index([email])
}

model AuditLog {
  id         String      @id @default(cuid())
  createdAt  DateTime    @default(now())
  action     AuditAction
  actorId    String?
  actorEmail String?
  targetType String?
  targetId   String?
  detail     String?
  actor      AdminUser?  @relation(fields: [actorId], references: [id])

  @@index([createdAt])
  @@index([action])
}

model MobilityReview {
  id                     String         @id @default(cuid())
  reference              String?        @unique
  createdAt              DateTime       @default(now())
  updatedAt              DateTime       @updatedAt
  fullName               String
  phone                  String
  email                  String?
  currentLocation        String?
  destinationCountry     String
  matterType             MatterType
  paymentStatus          PaymentStatus?
  amountPaidOrRequested  String?
  agentCompanyEmployer   String?
  promiseMade            String?
  documentsAvailable     String?
  mainConcern            String
  preferredContactMethod ContactMethod?
  complianceAcknowledged Boolean        @default(false)
  status                 ReviewStatus   @default(NEW)
  internalNote           String?
  documents              DocumentRecord[]

  @@index([status])
  @@index([createdAt])
}

model RiskCheck {
  id                 String           @id @default(cuid())
  createdAt          DateTime         @default(now())
  destinationCountry String
  mainConcern        String
  selectedFlags      String[]
  redFlagCount       Int
  riskLevel          RiskLevel
  optionalName       String?
  optionalPhone      String?
  optionalEmail      String?
  status             RiskStatus       @default(NEW)
  internalNote       String?
  documents          DocumentRecord[]

  @@index([riskLevel])
  @@index([createdAt])
}

model DocumentRecord {
  id          String          @id @default(cuid())
  createdAt   DateTime        @default(now())
  fileName    String
  fileType    String?
  fileSize    Int?
  storageUrl  String?
  reviewId    String?
  riskCheckId String?
  note        String?
  review      MobilityReview? @relation(fields: [reviewId], references: [id])
  riskCheck   RiskCheck?      @relation(fields: [riskCheckId], references: [id])

  @@index([reviewId])
  @@index([riskCheckId])
}
