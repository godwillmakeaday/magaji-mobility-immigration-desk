# --- Database (Neon PostgreSQL) ---------------------------------------------
# Use the POOLED connection string from your Neon project dashboard.
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require"

# --- Admin authentication ---------------------------------------------------
# Secret used to sign admin session cookies. Generate a long random value, e.g.
#   openssl rand -base64 32
AUTH_SECRET="generate-a-long-random-secret"

# First owner account, created by `npm run db:seed`.
ADMIN_SEED_EMAIL="owner@yourfirm.com"
ADMIN_SEED_PASSWORD="change-this-strong-password"
ADMIN_SEED_NAME="Owner Name"

# --- WhatsApp lead flow -----------------------------------------------------
# International format, digits only, no "+" or spaces. e.g. 2348030000000
NEXT_PUBLIC_WHATSAPP_NUMBER="234XXXXXXXXXX"

# --- Email notifications (optional) -----------------------------------------
# New submissions email an alert to your team. If these are unset, notifications
# are silently skipped and submissions still save normally.
RESEND_API_KEY=""
NOTIFY_EMAIL_TO="ops@yourfirm.com"
NOTIFY_EMAIL_FROM="Magaji Law <alerts@yourdomain.com>"

# --- Document storage (Vercel Blob) -----------------------------------------
# Auto-provisioned when you create a Blob store in the Vercel dashboard
# (Storage -> Blob). For local dev, copy the token from that store's settings.
BLOB_READ_WRITE_TOKEN=""
